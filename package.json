{
  "name": "moneycircle",
  "private": true,
  "scripts": {
    "build": "npm run build --prefix frontend",
    "db:migrate:local": "wrangler d1 execute moneycircle --local --file=./migrations/0001_init.sql",
    "db:migrate:remote": "wrangler d1 execute moneycircle --remote --file=./migrations/0001_init.sql",
    "pages:dev": "npm run build && wrangler pages dev frontend/dist --d1=DB --local",
    "pages:deploy": "npm run build && wrangler pages deploy frontend/dist"
  },
  "devDependencies": {
    "wrangler": "^4.14.0"
  }
}
