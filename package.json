{
  "name": "moneycircle",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "db:migrate:local": "wrangler d1 execute vibe_code_training --local --file=./migrations/0001_init.sql && wrangler d1 execute vibe_code_training --local --file=./migrations/0002_social.sql && wrangler d1 execute vibe_code_training --local --file=./migrations/0003_social_engagement.sql",
    "db:migrate:remote": "wrangler d1 execute vibe_code_training --remote --file=./migrations/0001_init.sql && wrangler d1 execute vibe_code_training --remote --file=./migrations/0002_social.sql && wrangler d1 execute vibe_code_training --remote --file=./migrations/0003_social_engagement.sql",
    "db:migrate:remote:all": "powershell -ExecutionPolicy Bypass -File ./scripts/migrate-remote.ps1",
    "db:migrate:social:local": "wrangler d1 execute vibe_code_training --local --file=./migrations/0002_social.sql",
    "db:migrate:engagement:local": "wrangler d1 execute vibe_code_training --local --file=./migrations/0003_social_engagement.sql",
    "db:migrate:engagement:remote": "wrangler d1 execute vibe_code_training --remote --file=./migrations/0003_social_engagement.sql",
    "db:migrate:repost-columns:local": "wrangler d1 execute vibe_code_training --local --file=./migrations/0004_social_repost_columns.sql",
    "db:migrate:repost-columns:remote": "wrangler d1 execute vibe_code_training --remote --file=./migrations/0004_social_repost_columns.sql",
    "db:migrate:bio:local": "wrangler d1 execute vibe_code_training --local --file=./migrations/0002_user_bio.sql",
    "db:migrate:bio:remote": "wrangler d1 execute vibe_code_training --remote --file=./migrations/0002_user_bio.sql",
    "db:migrate:chat:local": "wrangler d1 execute vibe_code_training --local --file=./migrations/0005_chat_history.sql",
    "db:migrate:chat:remote": "wrangler d1 execute vibe_code_training --remote --file=./migrations/0005_chat_history.sql",
    "pages:dev": "npm run build && npm run db:migrate:local && wrangler pages dev dist --d1=65b810fc-498b-4575-8e3c-f0b4a8413d04 --local",
    "pages:deploy": "npm run build && wrangler pages deploy dist"
  },
  "dependencies": {
    "dompurify": "^3.4.11",
    "jose": "^5.9.6",
    "lucide-vue-next": "^1.0.0",
    "markdown-it": "^14.3.0",
    "openai": "^4.82.0",
    "pinia": "^2.3.0",
    "vue": "^3.5.38",
    "vue-i18n": "^11.4.6"
  },
  "devDependencies": {
    "@pinia/nuxt": "^0.9.0",
    "@tailwindcss/vite": "^4.3.2",
    "@vite-pwa/nuxt": "^1.1.1",
    "nuxt": "^3.12.4",
    "tailwindcss": "^4.3.2",
    "wrangler": "^4.14.0"
  }
}
