{
  "name": "moneycircle",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "db:migrate:local": "wrangler d1 execute moneycircle --local --file=./migrations/0001_init.sql",
    "db:migrate:remote": "wrangler d1 execute moneycircle --remote --file=./migrations/0001_init.sql",
    "pages:dev": "npm run build && wrangler pages dev .output/public --d1=DB --local",
    "pages:deploy": "npm run build && wrangler pages deploy .output/public"
  },
  "dependencies": {
    "dompurify": "^3.4.11",
    "jose": "^5.9.6",
    "lucide-vue-next": "^1.0.0",
    "markdown-it": "^14.3.0",
    "openai": "^4.82.0",
    "pinia": "^2.3.0",
    "vue": "^3.5.38",
    "vue-i18n": "^11.4.6"
  },
  "devDependencies": {
    "@pinia/nuxt": "^0.9.0",
    "@tailwindcss/vite": "^4.3.2",
    "nuxt": "^3.12.4",
    "tailwindcss": "^4.3.2",
    "vite-plugin-pwa": "^0.21.1",
    "wrangler": "^4.14.0"
  }
}
